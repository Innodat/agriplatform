# services/app-directory — environment variables
# Copy to .env and fill in values

# JWT — Supabase project JWT secret (Settings → API → JWT Secret)
# Used to verify Bearer tokens from app frontends.
SUPABASE_JWT_SECRET=your-jwt-secret

# App
APP_ENV=development
CORS_ORIGINS=["http://localhost:5174","http://localhost:5175","http://localhost:3000"]

# App URLs (override in production)
APP_URL_SCRIBESWELL=http://localhost:5174
APP_URL_SYSTEM_ENGINEERING=http://localhost:5175
APP_URL_BUDGETING=http://localhost:5176
APP_URL_SCHOOL_MANAGEMENT=http://localhost:5177
APP_URL_MODELLING_SIMULATION=http://localhost:5178
