{
  "name": "agriplatform",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "platform/*",
    "apps/scribeswell",
    "tools"
  ],
  "scripts": {
    "tools": "python tools/tools.py",
    "dev": "npm run tools -- tailwind --watch",
    "build": "npm run tools -- tailwind --minify",
    "db:compose": "python tools/tools.py compose_supabase",
    "db:compose:check": "python tools/tools.py compose_supabase --check-only",
    "db:push:local": "npm run db:compose && npx supabase db push --workdir supabase --local",
    "db:push": "npm run db:compose && npx supabase db push --workdir supabase",
    "fn:deploy": "npm run db:compose && npx supabase functions deploy --workdir supabase"

  },
  "devDependencies": {
    "supabase": "^2.72.8",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0",
    "zod": "^3.22.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Innodat/agriplatform.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Innodat/agriplatform/issues"
  },
  "homepage": "https://github.com/Innodat/agriplatform#readme",
  "description": "",
  "dependencies": {
    "@azure/storage-blob": "^12.29.1",
    "@supabase/supabase-js": "^2.76.1"
  }
}
